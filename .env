# Logging verbosity (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

WAIT_FOR_TX_CONFIRMATIONS=FALSE
WAIT_FOR_VERIFICATION_RESULT=TRUE

# Sleep between consecutive measurements in milliseconds.
# 0 = run measurements back-to-back, bounded only by CPU_LIMIT (cgroup).
# Increase if you need a wider local vulnerability window for security/perf tuning.
ATTESTATION_INTERVAL_MS=20000
CPU_LIMIT=0.4
# IterQ (rolling hash) threshold K: number of fresh measurements folded into
# one on-chain attestation. K=1 = single-shot, K>1 = rolling-hash chain.
ITERQ_THRESHOLD=1

ENABLE_LIBS_HASH=FALSE
SELF_INTEGRITY_ENABLED=TRUE

# Auto-start background workers/watchers on app boot (TRUE/FALSE)
AUTO_START=TRUE

EXPORT_RESULTS=FALSE

# Output directory for exported results
RESULTS_DIR=/experiments/data/attestation-times/results/N4/startup

USE_REDIS=FALSE

ONE_SHOT=FALSE

# EventWatcher: how many blocks behind head to process logs
EVENT_CONFIRMATIONS=0

# EventWatcher: seconds between polling eth_getLogs when caught up
EVENT_POLL_INTERVAL=0.2

# EventWatcher: max block range per eth_getLogs request
EVENT_BATCH_SIZE=500

ROS_DOMAIN_ID=42

# Database (PostgreSQL)
PGDATA=/var/lib/postgresql/data/pgdata
POSTGRES_PASSWORD=postgres
POSTGRES_USER=postgres
POSTGRES_DB=attestation
RUN_ID=5

COMPOSE_PROJECT_NAME=ros2-b-mutra
N_ROBOTS=8
DEPLOY_MODE=remote
